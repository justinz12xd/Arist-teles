OPENAI_API_KEY=
OPENAI_FAST_MODEL=gpt-5.6-luna
OPENAI_VERIFY_MODEL=gpt-5.6-terra
OPENAI_DEEP_MODEL=gpt-5.6-sol
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
INSFORGE_BASE_URL=
INSFORGE_ANON_KEY=
# Optional: only required for server-side maintenance operations. User JWTs are
# used for normal requests so Row Level Security remains in effect.
INSFORGE_API_KEY=
# Required in production to ensure only the Next.js server can invoke the
# unauthenticated public-chat bridge. Use the same value in the root .env.local.
ARISTOTELES_API_SHARED_SECRET=
RAG_CHUNK_TOKENS=700
RAG_CHUNK_OVERLAP_TOKENS=100
RAG_EMBEDDING_BATCH_SIZE=64
RAG_DEFAULT_TOP_K=5
RAG_MAX_TOP_K=10
RAG_MIN_SIMILARITY=0.20
RAG_MAX_DOCUMENT_PAGES=250
RAG_MAX_DOCUMENT_CHARS=2000000
RAG_MAX_QUESTION_CHARS=4000
PROVIDER_TIMEOUT_SECONDS=30
PROVIDER_MAX_RETRIES=2
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]
LANGSMITH_TRACING=false
