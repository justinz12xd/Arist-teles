# Used when the backend is deployed separately.
# Docker Compose sets this automatically to http://backend:8080.
# In Vercel Services, the frontend service receives BACKEND_URL via vercel.json bindings.
ARISTOTELES_API_URL=http://localhost:8080
# Shared only between the Next.js server and FastAPI in production. Never prefix
# this variable with NEXT_PUBLIC_.
ARISTOTELES_API_SHARED_SECRET=
