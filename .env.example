# Used when the backend is deployed separately.
# Docker Compose sets this automatically to http://backend:8080.
# Server-side proxy target for Next API routes. In Vercel Services, the frontend service may receive BACKEND_URL via bindings.
ARISTOTELES_API_URL=http://localhost:8000
# Optional: bypass the Next proxy and call FastAPI directly from the browser. Usually leave empty in production.
NEXT_PUBLIC_ARISTOTELES_API_URL=
# Shared only between the Next.js server and FastAPI in production. Never prefix
# this variable with NEXT_PUBLIC_.
ARISTOTELES_API_SHARED_SECRET=
