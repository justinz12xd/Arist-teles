{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "frontend": {
      "root": ".",
      "entrypoint": "Dockerfile.vercel",
      "runtime": "container",
      "bindings": [
        {
          "type": "service",
          "service": "backend",
          "format": "url",
          "env": "BACKEND_URL"
        }
      ]
    },
    "backend": {
      "root": "backend/",
      "entrypoint": "Dockerfile.vercel",
      "runtime": "container",
      "memory": 2048,
      "maxDuration": 300,
      "routes": [
        {
          "src": "/svc/api",
          "transforms": [
            {
              "type": "request.path",
              "op": "set",
              "args": "/"
            }
          ]
        },
        {
          "src": "/svc/api/(.*)",
          "transforms": [
            {
              "type": "request.path",
              "op": "set",
              "args": "/$1"
            }
          ]
        }
      ]
    }
  },
  "rewrites": [
    {
      "source": "/svc/api/:path*",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "service": "frontend"
      }
    }
  ]
}
